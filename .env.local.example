# ============================================================
# BuildChain Protocol — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (get from: app.supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (http://localhost:3000 for dev, your Vercel URL for prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend — get from: resend.com)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=notifications@yourdomain.com

# Optional: Sentry for error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://...

# XRPL Escrow (run: node scripts/generate-xrpl-wallet.mjs to generate testnet wallets)
# Switch XRPL_NETWORK to wss://xrplcluster.com for mainnet
XRPL_NETWORK=wss://s.altnet.rippletest.net:51233
XRPL_WALLET_SEED=s...              # Platform wallet seed (signs escrow transactions)
XRPL_WALLET_ADDRESS=r...           # Platform wallet address (for reference)
XRPL_DEFAULT_DESTINATION=r...      # Default borrower XRP address on testnet
XRPL_ESCROW_FINISH_AFTER_SECONDS=30  # Seconds before escrow can be released (30 for testnet, 86400 for prod)
